#!/usr/bin/env bash

set -eu
set -o pipefail

: ${DOTFILES_PATH:="$HOME/dotfiles"}
: ${DOTFILES_BRANCH:=master}

print_title() {
  printf '\033[34m'
  cat <<'EOF'

                    https://github.com/yamadayuki/dotfiles

                             __      __  _____ __
                        ____/ /___  / /_/ __(_) /__  _____
                       / __  / __ \/ __/ /_/ / / _ \/ ___/
                     _/ /_/ / /_/ / /_/ __/ / /  __(__  )
                    (_)__,_/\____/\__/_/ /_/_/\___/____/

EOF
  printf '\033[0m\n'
}

print_done() {
  printf '\033[34m'
  cat <<'EOF'

                              ____
                             / __ \____  ____  ___
                            / / / / __ \/ __ \/ _ \
                           / /_/ / /_/ / / / /  __/
                          /_____/\____/_/ /_/\___(_)

EOF
  printf '\033[0m\n'
}

clone_or_update_repo() {
  local git_dir="$DOTFILES_PATH/.git"

  if [ -d "$git_dir" ]; then
    echo 'Updating repo...'

    if [ "$(git --git-dir="$git_dir" --work-tree="$DOTFILES_PATH" symbolic-ref --short HEAD 2> /dev/null)" != "master" ]; then
      echo 'skip (working on a non-master branch)'
      return
    fi

    if ! git --git-dir="$git_dir" --work-tree="$DOTFILES_PATH" diff --no-ext-diff --quiet --exit-code > /dev/null 2>&1; then
      echo 'skip (unstaged changes present)'
      return
    fi

    if ! git --git-dir="$git_dir" --work-tree="$DOTFILES_PATH" diff-index --cached --quiet HEAD -- > /dev/null 2>&1; then
      echo 'skip (uncommitted changes present)'
      return
    fi

    git --git-dir="$git_dir" --work-tree="$DOTFILES_PATH" pull origin master
    echo 'done'
  elif ! [ -d "$DOTFILES_PATH" ]; then
    echo 'Cloning repo...'
    git clone https://github.com/yamadayuki/dotfiles.git --branch $DOTFILES_BRANCH $DOTFILES_PATH
    echo 'done'
  fi
}

install_homebrew() {
  command -v 'brew' > /dev/null 2>&1 && return

  echo 'Installing homebrew...'
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  echo 'done'
}

install_mise() {
  export PATH="$HOME/.local/bin:$PATH"
  command -v 'mise' > /dev/null 2>&1 && return

  echo 'Installing mise...'
  curl https://mise.run | sh
  echo 'done'
}

run_mise_bootstrap() {
  export PATH="$HOME/.local/bin:$PATH"

  echo 'Running mise bootstrap...'
  mise trust "$DOTFILES_PATH"
  # config/mise/config.toml is only discovered indirectly (symlinked into
  # ~/.config/mise/conf.d/), not via mise's standard project-file discovery,
  # so `mise trust`/`--all` above never sees it. Its tasks use template
  # syntax ({{cwd}}), so without this it gets silently auto-ignored the
  # first time mise reads it non-interactively.
  mise trust "$DOTFILES_PATH/config/mise/config.toml"
  mise bootstrap --cd "$DOTFILES_PATH" --yes
  echo 'done'
}

main() {
  print_title
  clone_or_update_repo
  install_homebrew
  install_mise
  run_mise_bootstrap
  print_done
}

main
